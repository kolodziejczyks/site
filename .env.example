# Copy to .env and fill in. .env is git-ignored — never commit real tokens.

# Long-lived Instagram Graph API token (60 days; refresh before expiry).
# This is the only value you must set — get it from the Meta App Dashboard:
# Instagram > API Setup with Instagram Login > Generate Token.
IG_ACCESS_TOKEN=

# Optional — the script resolves your numeric id + username from the token.
# Only set this to override the auto-detected id.
# IG_USER_ID=

# Optional override:
# IG_API_BASE=https://graph.instagram.com/v21.0
